{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "exactOptionalPropertyTypes": false,
    "ignoreDeprecations": "6.0",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "node",
    "newLine": "lf",
    "noEmitOnError": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": ["src/**/*.ts"]
}
