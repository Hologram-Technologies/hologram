{
  "name": "@uor-foundation/wasm",
  "version": "0.12.1",
  "description": "WASM binding adapter for the Hologram TypeScript SDK",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "driver/Cargo.lock",
    "driver/Cargo.toml",
    "driver/src",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:driver": "node scripts/cargo-wasm.mjs check",
    "build:driver": "node scripts/cargo-wasm.mjs build",
    "build:all": "npm run build && npm run build:driver",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:check": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@uor-foundation/sdk": "0.12.1"
  },
  "devDependencies": {
    "typescript": ">=5.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hologram-Technologies/hologram.git",
    "directory": "sdk/typescript/wasm"
  }
}
